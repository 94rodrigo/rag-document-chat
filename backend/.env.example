# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://citenest:citenest@localhost:5432/citenest
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Storage (S3 / MinIO / local) ──────────────────────────────────────────────
# Use STORAGE_PROVIDER=local for development without MinIO/S3
# Files will be stored in ./storage/ relative to the backend directory
STORAGE_PROVIDER=local          # local | s3 | minio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=citenest-documents
S3_ENDPOINT_URL=http://localhost:9000   # remove for real S3

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai             # openai | anthropic
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# ── Billing ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Observability ──────────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | console (always use json in production)
METRICS_AUTH_TOKEN=          # set a strong random token to protect /metrics in production

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANONYMOUS_RPM=10
RATE_LIMIT_FREE_RPM=60
RATE_LIMIT_PRO_RPM=300
# Number of trusted reverse proxies in front of the app. 0 (default) = ignore
# X-Forwarded-For and rate-limit by the direct socket peer. Set to the number of
# trusted proxy hops (e.g. 1 for a single nginx) so the real client IP is read
# safely from the right of the X-Forwarded-For chain. Uvicorn is launched with
# --no-proxy-headers so this app setting is the only thing that trusts XFF.
TRUSTED_PROXY_COUNT=0

# ── Plans ──────────────────────────────────────────────────────────────────────
PLAN_FREE_DOCUMENTS=10
PLAN_FREE_QUERIES_PER_MONTH=100
PLAN_FREE_STORAGE_BYTES=52428800     # 50 MB
PLAN_PRO_DOCUMENTS=-1                # unlimited
PLAN_PRO_QUERIES_PER_MONTH=2000
PLAN_PRO_STORAGE_BYTES=10737418240   # 10 GB

# ── RAG ────────────────────────────────────────────────────────────────────────
# Embedder: openai | voyage | bge
RAG_EMBEDDER=openai
RAG_EMBEDDING_DIMENSIONS=1536        # 1536=openai-small, 1024=voyage-3/bge-large

# VoyageAI (when RAG_EMBEDDER=voyage)
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3

# BGE local model (when RAG_EMBEDDER=bge)
BGE_MODEL_NAME=BAAI/bge-large-en-v1.5
BGE_DEVICE=cpu                       # cpu | cuda

# Chunker: recursive | semantic | hybrid
RAG_CHUNKER=hybrid
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Retriever: dense | bm25 | hybrid
RAG_RETRIEVER=hybrid
RAG_PRE_RERANK_TOP_K=20

# Reranker
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_TOP_K=6

# Vector store: pgvector | qdrant
RAG_VECTOR_STORE=pgvector
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=citenest_chunks
